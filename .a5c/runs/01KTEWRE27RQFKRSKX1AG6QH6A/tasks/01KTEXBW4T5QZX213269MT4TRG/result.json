          "recordCrossTenantAccess writes one audit row",
          "admin path writes one row, normal read writes none",
          "admin_audit_log readable only under is_platform_admin"
        ],
        "criterion": "AC4 cross-tenant audit",
        "path": "services/authorizer/test/admin-audit.integration.test.ts",
        "tier": "integration"
      },
      {
        "assertions": [

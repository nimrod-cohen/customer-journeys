          "authorizer -> requestContext workspace_id=wsA -> scoped data",
          "body workspace_id=wsB ignored",
          "minimal: one allow + one deny"
        ],
        "criterion": "AC1/3/5 wiring",
        "path": "tests/e2e/authorizer-api.e2e.test.ts",
        "tier": "e2e"
      }

    ],
    "notes": "§6 tenancy tables (0002) + RLS (0006) ALREADY EXIST with FORCE RLS, uniform tenant_isolation policy, narrow OR app_is_platform_admin() exception, platform_only policies, workspace_users self-membership carve-out for switcher. profiles UNIQUE(workspace_id,external_id) in 0003. RLS helpers read current_setting('request.jwt.claims',true)::jsonb -> integration tests set claim via set_config, not real JWT. CRITICAL: run RLS integration tests as non-superuser WITHOUT BYPASSRLS or they pass vacuously; use separate service-role connection to seed and to prove bypass. Mock JWKS/jose + AWS SDK; never mock Postgres. Add jose dep to authorizer, pg/testcontainers to db tests.",
    "pureFunctions": [
      "can(role,capability)",
      "requireCapability(ctx,capability)",
      "resolveRole(memberships,activeWorkspaceId)",
      "switchActiveWorkspace(memberships,target,isPlatformAdmin)",
      "buildJwtClaims(ctx)",
      "authorize(decodedJwt,membership,isPlatformAdmin)",
      "buildAuthorizerPolicy(authResult)",
      "recordCrossTenantAccess(userId,workspaceId,action,detail)",
      "isCrossTenantAccess(ctx,targetWorkspaceId)",
      "scopedQuery(workspaceId,fragment,params)"
    ],
    "testFiles": [
      {
        "assertions": [
          "connect as non-superuser non-BYPASSRLS app role so FORCE RLS applies",
          "seed wsA/wsB rows via service-role",
          "set request.jwt.claims via set_config and assert app_current_workspace_id()",
          "SELECT returns only wsA rows",
          "UPDATE WHERE workspace_id=wsB affects 0 rows",
          "INSERT with wsB under wsA claim rejected by WITH CHECK",
          "repeat across all tenant tables",
          "switch claim to wsB, symmetric result"
        ],
        "criterion": "AC1 RLS read/write isolation",
        "path": "packages/db/test/rls-isolation.integration.test.ts",
        "tier": "integration"
      },
      {
        "assertions": [
          "service-role connection bypasses RLS (sees both workspaces)",
          "scopedQuery helper always emits workspace_id=$n bound to wsA",
          "returns only wsA rows despite bypass-capable connection",
          "throws if no workspaceId"
        ],
        "criterion": "AC1 service-role in-code scoping",
        "path": "services/api/test/service-role-scoping.integration.test.ts",
        "tier": "integration"
      },
      {
        "assertions": [
          "same external_id in wsA and wsB both succeed",
          "second same external_id in wsA fails 23505",
          "distinct profile.id",
          "wsA claim sees exactly one"
        ],
        "criterion": "AC2 per-workspace uniqueness",
        "path": "packages/db/test/per-workspace-uniqueness.integration.test.ts",
        "tier": "integration"
      },
      {
        "assertions": [
          "can() pure, table-driven over §3A",
          "marketer denied users/domain/billing",
          "accounting billing_view only",
          "owner all within workspace not view_all_workspaces",
          "system-admin all incl view_all_workspaces",
          "unknown => deny no throw"
        ],
        "criterion": "AC3 capability matrix",
        "path": "packages/tenancy/test/role-capability-matrix.test.ts",
        "tier": "unit"
      },
      {
        "assertions": [
          "requireCapability denies marketer on manage_users/domain/billing",
          "accounting denied segment/campaign edit, allowed billing read",
          "owner allowed users+billing",
          "deny carries reason no data"
        ],
        "criterion": "AC3 route gate",
        "path": "services/api/test/route-role-enforcement.test.ts",
        "tier": "unit"
      },
      {
        "assertions": [
          "authorize() pure, JWKS injected",
          "valid JWT wsA+marketer injects context",
          "platform_admins lookup sets isPlatformAdmin",
          "active workspace not in memberships and not admin => Deny",
          "expired/invalid/missing-sub => Deny",
          "never uses body workspace_id"
        ],
        "criterion": "AC3/4/5 authorizer core",
        "path": "services/authorizer/test/authorize.test.ts",
        "tier": "unit"
      },
      {

    "@cdp/service-authorizer": "workspace:*",
    "@cdp/service-ingest": "workspace:*",
    "@cdp/service-processor": "workspace:*",
    "@cdp/shared": "workspace:*",
    "@cdp/tenancy": "workspace:*"
  },
  "devDependencies": {
    "aws-sdk-client-mock": "^4.0.1"
  }
}

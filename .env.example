# Local development environment (LOCAL ONLY — no cloud credentials here).

# Postgres (Supabase CLI local default)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
# Pooled connection (Supabase pgbouncer / Lambda parity). Defaults to DATABASE_URL locally.
DATABASE_POOL_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# LocalStack (SQS/S3/SNS/API GW)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://127.0.0.1:4566
